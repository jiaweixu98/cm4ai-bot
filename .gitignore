# Secrets (never commit credentials)
backend/.env
backend/.env.*
!backend/.env.example
frontend/.env.local
frontend/.env.local.*
!frontend/.env.local.example
.env

# Node
node_modules/
.next/
npm-debug.log*

# Virtual environment
.venv/
backend/.venv/

